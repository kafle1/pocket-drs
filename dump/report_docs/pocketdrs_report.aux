\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Real-world test footage: opening frame from the bowler-end stumps (left) and mid-delivery action (right). The pipeline ran end-to-end on this clip and produced an OUT decision.}}{25}{figure.caption.6}\protected@file@percent }
\newlabel{fig:real_validation}{{6}{25}{Real-world test footage: opening frame from the bowler-end stumps (left) and mid-delivery action (right). The pipeline ran end-to-end on this clip and produced an OUT decision}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Diagnostic visualisations of the real run.}{26}{figure.caption.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Real-video diagnostics. Left: the manually-tapped pitch polygon overlaid on frame 0. Right: every per-frame ``ball'' detection drawn on a single frame, showing all 174 detections cluster within a $2.5 \times 97.5$ pixel region. The detector locked onto a stationary red/brown object near the batter rather than the moving cricket ball, because the source clip is a social-media reel with cuts rather than a continuous umpire-POV delivery shot.}}{26}{figure.caption.7}\protected@file@percent }
\newlabel{fig:realvideo_diag}{{7}{26}{Real-video diagnostics. Left: the manually-tapped pitch polygon overlaid on frame 0. Right: every per-frame ``ball'' detection drawn on a single frame, showing all 174 detections cluster within a $2.5 \times 97.5$ pixel region. The detector locked onto a stationary red/brown object near the batter rather than the moving cricket ball, because the source clip is a social-media reel with cuts rather than a continuous umpire-POV delivery shot}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Three.js render of the trajectory recovered from the real practice-nets video. The OUT verdict is displayed; the rendered trajectory collapses to a near-vertical column because the visually marked pitch corners produced a high-reprojection-error calibration, illustrating why precise tap calibration is required in production use.}}{27}{figure.caption.8}\protected@file@percent }
\newlabel{fig:realvideo_3d}{{8}{27}{Three.js render of the trajectory recovered from the real practice-nets video. The OUT verdict is displayed; the rendered trajectory collapses to a near-vertical column because the visually marked pitch corners produced a high-reprojection-error calibration, illustrating why precise tap calibration is required in production use}{figure.caption.8}{}}
