\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Three.js Hawk-Eye viewer renders for two synthetic scenarios. Left: a medium-pace, middle-stump delivery producing an OUT verdict. Right: a delivery pitched wide of off, returning NOT OUT. The cyan/blue line is the recovered ball trajectory; the orange line (when present) is the projectile extrapolated forward to the stump plane.}}{24}{figure.caption.4}\protected@file@percent }
\newlabel{fig:viewer_decisions}{{4}{24}{Three.js Hawk-Eye viewer renders for two synthetic scenarios. Left: a medium-pace, middle-stump delivery producing an OUT verdict. Right: a delivery pitched wide of off, returning NOT OUT. The cyan/blue line is the recovered ball trajectory; the orange line (when present) is the projectile extrapolated forward to the stump plane}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Side-on view of a recovered trajectory: ball release at the bowler end (right), parabolic descent to the pitch, bounce, post-bounce arc, and impact in front of the striker stumps (left).}}{24}{figure.caption.5}\protected@file@percent }
\newlabel{fig:trajectory_sideon}{{5}{24}{Side-on view of a recovered trajectory: ball release at the bowler end (right), parabolic descent to the pitch, bounce, post-bounce arc, and impact in front of the striker stumps (left)}{figure.caption.5}{}}
