<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>PocketDRS — 3D Hawk-Eye</title>
<style>
  html, body { margin: 0; height: 100%; overflow: hidden;
    background: radial-gradient(120% 90% at 50% 18%, #16324d 0%, #0a1622 55%, #060c14 100%);
    color: #eef3f8; font: 13px/1.4 -apple-system, "Segoe UI", system-ui, sans-serif; }
  #scene { position: absolute; inset: 0; }

  /* DRS decision panel stack (left) */
  #panels { position: absolute; top: 18px; left: 18px; display: flex;
            flex-direction: column; gap: 14px; }
  .pan { width: 150px; border-radius: 4px; overflow: hidden;
         box-shadow: 0 4px 14px rgba(0,0,0,.45); }
  .ph { background: #16335c; color: #fff; font-weight: 800; letter-spacing: .6px;
        font-size: 11px; padding: 7px 10px; }
  .pv { color: #fff; font-weight: 800; letter-spacing: .6px; font-size: 12px;
        padding: 7px 10px; }

  /* metric cards (right) */
  #metrics { position: absolute; top: 18px; right: 18px; display: flex;
             flex-direction: column; gap: 10px; align-items: flex-end; }
  .mc { background: rgba(12,18,26,.82); border: 1px solid rgba(255,255,255,.12);
        border-radius: 10px; padding: 8px 12px; min-width: 92px; text-align: right;
        backdrop-filter: blur(3px); }
  .mc span { display: block; font-size: 9px; letter-spacing: 1.4px; color: #93a3b4;
             font-weight: 700; }
  .mc b { font-size: 20px; font-weight: 800; }
  .mc i { font-style: normal; font-size: 11px; color: #aebccb; font-weight: 600; }

  #help { position: absolute; bottom: 14px; right: 16px; color: #5b6f84;
          font-size: 11px; }
  #legend { position: absolute; bottom: 14px; left: 18px; font-size: 11px;
            color: #aebccb; }
  #legend .dot { display: inline-block; width: 14px; height: 4px; border-radius: 2px;
                 vertical-align: middle; margin: 0 5px 2px 12px; }
</style>
</head>
<body>
<div id="scene"></div>

<div id="panels">
  <div class="pan"><div class="ph">PITCHING</div><div class="pv" id="p-pitch"></div></div>
  <div class="pan"><div class="ph">IMPACT</div><div class="pv" id="p-impact"></div></div>
  <div class="pan"><div class="ph">WICKETS</div><div class="pv" id="p-wickets"></div></div>
  <div class="pan"><div class="ph">DECISION</div><div class="pv" id="p-decision"></div></div>
</div>

<div id="metrics">
  <div class="mc"><span>SPEED</span><b id="m-speed">–</b> <i>km/h</i></div>
  <div class="mc"><span>SWING</span><b id="m-swing">–</b> <i>cm</i></div>
  <div class="mc"><span>SPIN</span><b id="m-spin">–</b> <i>deg</i></div>
</div>

<div id="legend">
  <span class="dot" style="background:#ff3b30"></span>tracked
  <span class="dot" style="background:#ff8a7a"></span>predicted
  <span class="dot" style="background:#3f8bff"></span>wicket zone
</div>
<div id="help">drag = orbit · scroll = zoom · right-drag = pan</div>

<script type="importmap">
{ "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
} }
</script>

<script type="module">
import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";

const PAYLOAD = __PAYLOAD__;

const L = PAYLOAD.pitch_length_m;
const PW = PAYLOAD.pitch_width_m;
const halfW = PW / 2;
const STUMP_H = 0.711;
const STUMP_DX = 0.114;
const CORR_HALF = STUMP_DX + 0.036;
const TARGET_X = 0; // striker stumps — the wicket judged

let W = window.innerWidth, H = window.innerHeight;

const scene = new THREE.Scene();
scene.fog = new THREE.Fog(0x0a1622, L + 6, L + 26);

const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(W, H);
renderer.setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
document.getElementById("scene").appendChild(renderer.domElement);

// Camera: low and slightly behind the STRIKER wicket (the judged end), so the
// blue wicket zone + stumps sit prominent in the foreground and the ball flies
// in toward them — the classic DRS "would it have hit?" framing.
const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 200);
camera.up.set(0, 0, 1);
camera.position.set(-3.4, 2.3, 1.7);

const controls = new OrbitControls(camera, renderer.domElement);
controls.target.set(L * 0.34, 0, 0.45);
controls.enableDamping = true;
controls.dampingFactor = 0.08;
controls.minDistance = 2.5;
controls.maxDistance = 40;
controls.maxPolarAngle = Math.PI * 0.49;
controls.update();

// Lighting — bright broadcast key from the umpire side + soft sky fill.
scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const key = new THREE.DirectionalLight(0xffffff, 1.0);
key.position.set(L + 6, 4, 8);
scene.add(key);
scene.add(new THREE.HemisphereLight(0xa9c7ff, 0x2a3a24, 0.5));

// --- outfield (large green ground plane) ------------------------------
{
  const g = new THREE.PlaneGeometry(60, 80);
  const m = new THREE.MeshStandardMaterial({ color: 0x1f6b34, roughness: 1.0 });
  const mesh = new THREE.Mesh(g, m);
  mesh.position.set(L / 2, 0, -0.01);
  scene.add(mesh);
}

// --- pitch strip (worn tan-green) -------------------------------------
{
  const g = new THREE.PlaneGeometry(L + 1.6, PW + 0.4);
  const m = new THREE.MeshStandardMaterial({ color: 0x9fa56a, roughness: 0.98 });
  const mesh = new THREE.Mesh(g, m);
  mesh.position.set(L / 2, 0, 0.0);
  scene.add(mesh);
  const inner = new THREE.Mesh(
    new THREE.PlaneGeometry(L + 1.6, 0.9),
    new THREE.MeshStandardMaterial({ color: 0x8b9158, roughness: 0.98 }),
  );
  inner.position.set(L / 2, 0, 0.001);
  scene.add(inner);
}

// --- white creases + stump-line markings ------------------------------
function whiteLine(a, b, op = 0.9, w = 2) {
  const g = new THREE.BufferGeometry().setFromPoints([
    new THREE.Vector3(a[0], a[1], a[2]), new THREE.Vector3(b[0], b[1], b[2]),
  ]);
  return new THREE.Line(g, new THREE.LineBasicMaterial({
    color: 0xf3f7fa, transparent: true, opacity: op, linewidth: w }));
}
const CREASE = 1.22;
for (const cx of [CREASE, L - CREASE, 0, L]) {
  scene.add(whiteLine([cx, -halfW, 0.004], [cx, halfW, 0.004], cx === 0 || cx === L ? 0.95 : 0.6));
}
scene.add(whiteLine([0, 0, 0.004], [L, 0, 0.004], 0.18)); // bowling line

// --- on-stumps corridor (translucent blue band on the ground) ---------
{
  const g = new THREE.PlaneGeometry(L, CORR_HALF * 2);
  const m = new THREE.MeshBasicMaterial({ color: 0x3f8bff, transparent: true,
    opacity: 0.12, side: THREE.DoubleSide });
  const mesh = new THREE.Mesh(g, m);
  mesh.position.set(L / 2, 0, 0.003);
  scene.add(mesh);
}

// --- BLUE wicket zone: vertical slab at the stump plane (would-hit volume)
{
  const g = new THREE.BoxGeometry(0.06, CORR_HALF * 2, STUMP_H);
  const m = new THREE.MeshBasicMaterial({ color: 0x3f8bff, transparent: true,
    opacity: 0.30, side: THREE.DoubleSide, depthWrite: false });
  const box = new THREE.Mesh(g, m);
  box.position.set(TARGET_X, 0, STUMP_H / 2);
  scene.add(box);
  const edges = new THREE.LineSegments(new THREE.EdgesGeometry(g),
    new THREE.LineBasicMaterial({ color: 0xbcd9ff, transparent: true, opacity: 0.95 }));
  edges.position.copy(box.position);
  scene.add(edges);
}

// --- stumps + bails ---------------------------------------------------
function makeStumps(x, color, scale, emissive = 0) {
  const group = new THREE.Group();
  const mat = new THREE.MeshStandardMaterial({ color, roughness: 0.5,
    emissive: emissive ? color : 0x000000, emissiveIntensity: emissive });
  const geom = new THREE.CylinderGeometry(0.016 * scale, 0.016 * scale, STUMP_H, 14);
  for (const dy of [-STUMP_DX, 0, STUMP_DX]) {
    const m = new THREE.Mesh(geom, mat);
    m.position.set(x, dy, STUMP_H / 2);
    m.rotation.x = Math.PI / 2;
    group.add(m);
  }
  const bgeom = new THREE.CylinderGeometry(0.009, 0.009, STUMP_DX + 0.02, 10);
  for (const off of [-STUMP_DX / 2, STUMP_DX / 2]) {
    const b = new THREE.Mesh(bgeom, mat);
    b.position.set(x, off, STUMP_H + 0.014);
    b.rotation.z = Math.PI / 2;
    group.add(b);
  }
  return group;
}
scene.add(makeStumps(TARGET_X, 0xf4f7fa, 1.0, 0.12));
scene.add(makeStumps(L - TARGET_X, 0xb9c0c9, 0.85));

// --- ball path as a solid tube ---------------------------------------
function tube(points, color, radius, opacity = 1.0, emissive = 0.25) {
  if (points.length < 2) return null;
  const v = points.map(p => new THREE.Vector3(p[0], p[1], Math.max(0.02, p[2])));
  const curve = new THREE.CatmullRomCurve3(v, false, "catmullrom", 0.5);
  const geo = new THREE.TubeGeometry(curve, Math.max(24, v.length * 8), radius, 14, false);
  const mat = new THREE.MeshStandardMaterial({
    color, emissive: color, emissiveIntensity: emissive, roughness: 0.35,
    transparent: opacity < 1, opacity });
  return { mesh: new THREE.Mesh(geo, mat), curve };
}
function groundShadow(points, color) {
  const v = points.map(p => new THREE.Vector3(p[0], p[1], 0.006));
  const curve = new THREE.CatmullRomCurve3(v);
  const geo = new THREE.TubeGeometry(curve, Math.max(24, v.length * 6), 0.022, 8, false);
  return new THREE.Mesh(geo, new THREE.MeshBasicMaterial({
    color, transparent: true, opacity: 0.18 }));
}

const tracked = PAYLOAD.tracked.map(p => [p.x, p.y, p.z]);
const predicted = PAYLOAD.predicted.map(p => [p.x, p.y, p.z]);
const impact = PAYLOAD.impact;
const impactPt = impact && Number.isFinite(impact.x_m)
  ? [impact.x_m, impact.y_m, Math.max(0.02, impact.z_m)] : null;

let fullCurve = null;
if (tracked.length >= 2) {
  const t = tube(tracked, 0xff3b30, 0.05, 1.0, 0.3);
  scene.add(t.mesh);
  scene.add(groundShadow(tracked, 0xff3b30));
  fullCurve = t.curve;
}
if (predicted.length >= 2) {
  const lead = impactPt ? [impactPt] : [];
  const pts = [...lead, ...predicted];
  const t = tube(pts, 0xff8a7a, 0.042, 0.92, 0.2);
  scene.add(t.mesh);
  scene.add(groundShadow(pts, 0xff8a7a));
}

// --- pitching + impact markers ----------------------------------------
const bounce = PAYLOAD.bounce;
if (bounce && Number.isFinite(bounce.x_m)) {
  const disc = new THREE.Mesh(new THREE.CircleGeometry(0.12, 32),
    new THREE.MeshBasicMaterial({ color: 0xffd166, transparent: true, opacity: 0.7 }));
  disc.position.set(bounce.x_m, bounce.y_m, 0.01);
  scene.add(disc);
  const ring = new THREE.Mesh(new THREE.RingGeometry(0.12, 0.15, 32),
    new THREE.MeshBasicMaterial({ color: 0xffe39a, side: THREE.DoubleSide }));
  ring.position.set(bounce.x_m, bounce.y_m, 0.011);
  scene.add(ring);
}
if (impactPt) {
  const m = new THREE.Mesh(new THREE.SphereGeometry(0.05, 18, 18),
    new THREE.MeshStandardMaterial({ color: 0x22d3ee, emissive: 0x22d3ee,
      emissiveIntensity: 0.5 }));
  m.position.set(impactPt[0], impactPt[1], impactPt[2]);
  scene.add(m);
}

// --- moving ball along the full path ----------------------------------
const ball = new THREE.Mesh(new THREE.SphereGeometry(0.055, 20, 20),
  new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0xff5a4a,
    emissiveIntensity: 0.45, roughness: 0.3 }));
scene.add(ball);

// --- HUD: panels + metrics --------------------------------------------
const GRN = "#2faa4a", RED = "#d23b2f", YEL = "#e0a52b";
const c = PAYLOAD.checks || {};
function setPanel(id, text, col) {
  const el = document.getElementById(id);
  el.textContent = text;
  el.style.background = col;
}
setPanel("p-pitch", c.pitching_in_line ? "IN LINE" : "OUTSIDE",
         c.pitching_in_line ? RED : GRN);
setPanel("p-impact", c.impact_in_line ? "IN LINE" : "OUTSIDE OFF",
         c.impact_in_line ? RED : GRN);
setPanel("p-wickets", c.wickets_hitting ? "HITTING" : "MISSING",
         c.wickets_hitting ? RED : GRN);
const dec = (PAYLOAD.lbw_decision || "?").toUpperCase().replace(/_/g, " ");
setPanel("p-decision", dec,
         dec === "OUT" ? RED : dec === "NOT OUT" ? GRN : YEL);

document.getElementById("m-speed").textContent = PAYLOAD.speed_kmh.toFixed(0);
document.getElementById("m-swing").textContent = (PAYLOAD.swing_cm || 0).toFixed(0);
document.getElementById("m-spin").textContent = (PAYLOAD.spin_deg || 0).toFixed(1);

// --- resize + animation loop ------------------------------------------
window.addEventListener("resize", () => {
  W = window.innerWidth; H = window.innerHeight;
  renderer.setSize(W, H);
  camera.aspect = W / H; camera.updateProjectionMatrix();
});

let t0 = null;
const LOOP_MS = 2600, HOLD_MS = 900;
function tick(now) {
  if (t0 === null) t0 = now;
  if (fullCurve) {
    const phase = ((now - t0) % (LOOP_MS + HOLD_MS)) / LOOP_MS;
    const u = Math.min(1, Math.max(0, phase));
    const p = fullCurve.getPointAt(u);
    ball.position.copy(p);
    ball.visible = phase <= 1.02;
  }
  controls.update();
  renderer.render(scene, camera);
  requestAnimationFrame(tick);
}
requestAnimationFrame(tick);
</script>
</body>
</html>
